<Project Sdk="Atya.Build.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>Atya.Errors.Exceptions</PackageId>
    <AssemblyName>Atya.Errors.Exceptions</AssemblyName>
    <RootNamespace>Atya.Errors.Exceptions</RootNamespace>
    <IsPackable>true</IsPackable>
    <Authors>Arsen Asulyan</Authors>
    <Copyright>Copyright (c) 2026 Arsen Asulyan</Copyright>
    <Description>Exception types and helpers for Atya error handling packages.</Description>
    <PackageTags>dotnet;errors;exceptions;atya</PackageTags>
    <RepositoryUrl>https://github.com/AtyaLibraries/Exceptions</RepositoryUrl>
    <PackageProjectUrl>$(RepositoryUrl)</PackageProjectUrl>
    <NoWarn>$(NoWarn);RS0026;SA1611;SA1615;SA1313</NoWarn>

    <!-- MinVer derives the version from git tags (e.g. tag `v1.2.3` -> 1.2.3). -->
    <MinVerDefaultPreReleaseIdentifiers>alpha.0</MinVerDefaultPreReleaseIdentifiers>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="" />
    <None Include="..\..\LICENSE" Pack="true" PackagePath="" Visible="false" />
  </ItemGroup>

  <ItemGroup Label="Runtime dependencies">
    <PackageReference Include="Atya.Foundation.Guards" />
  </ItemGroup>

</Project>
